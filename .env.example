# Gizli ayarlar şablonu. Bu dosyayı ".env" olarak kopyala ve doldur.
# ".env" git'e ASLA girmez (.gitignore'da). Buradaki değerler boş kalmalı.

# --- Piyasa verisi / CANLI işlem anahtarı ---
# Genel piyasa verisi (OHLCV/fiyat) için anahtar GEREKMEZ — bot anahtarsız okur.
# Anahtar yalnız (a) hesap-bağlı veri ya da (b) CANLI otonom işlem için gerekir.
# CANLI kullanılacaksa izinler: "Enable Spot Trading" AÇIK, "Enable Withdrawals" KAPALI,
# IP whitelist ekli. Yalnızca analiz/veri için kullanacaksan Trading'i de KAPALI tut.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Binance Spot TESTNET (sahte para; https://testnet.binance.vision) ---
# execution.mode: testnet için gerekir. Testnet anahtarı canlı anahtardan AYRIDIR.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- CANLI İŞLEM ANA KİLİDİ (üçlü kilidin 1. parçası) ---
# 0 = kapalı (gerçek emir gönderilmez). Canlı için: bu 1 OLMALI + config execution.mode: live
# + CLI --live (üçü birden). Biri eksikse canlı emir REDDEDİLİR.
LIVE_TRADING=0

# Telegram bildirimi (opsiyonel). Token yoksa bot sessizce sadece konsola yazar.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Loglama seviyesi: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# SQLite veritabanı (SQLAlchemy URL biçimi)
DB_URL=sqlite:///signals.db
